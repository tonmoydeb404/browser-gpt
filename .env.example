# Browser GPT — environment variables
#
# Copy this file to `.env` and fill in values to prefill the onboarding wizard.
# These are inlined at BUILD time (Vite/WXT) and are used only to prefill the
# wizard inputs; they are not a runtime fallback.
#
# WARNING: Anything set here is baked into the built extension bundle. Do NOT
# put secrets in a build you distribute publicly.

# Display name shown in the sidebar (optional)
VITE_BROWSER_GPT_USERNAME=

# OpenRouter API key (optional). Get one at https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=

# Default model id, e.g. anthropic/claude-3.5-sonnet (optional)
VITE_BROWSER_GPT_MODEL=
